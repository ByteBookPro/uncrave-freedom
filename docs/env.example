# Client (Vite — must be prefixed VITE_)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...   # anon key, safe in browser
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Server (edge functions + scripts) — set via `supabase secrets set`
OPENAI_API_KEY=sk-...                          # TTS + image gen (required)
LOVABLE_API_KEY=...                            # optional gateway fallback
GEMINI_API_KEY=...                             # optional, for gemini-* fns

# Auto-provisioned by Supabase, do not set manually
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
